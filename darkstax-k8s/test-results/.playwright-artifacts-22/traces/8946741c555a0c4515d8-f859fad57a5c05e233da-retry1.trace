n  background: var(--color-red-700);\n}\n\n.tag--danger .tag__remove svg {\n  color: white;\n}\n\n/* Positive scheme */\n.tag--positive {\n  background: var(--color-green-800);\n  color: var(--sds-color-text-positive-on-positive);\n}\n\n.tag--positive:hover,\n.tag--positive.tag--hover {\n  background: var(--color-green-600);\n}\n\n.tag--positive .tag__remove svg {\n  color: white;\n}\n\n/* Warning scheme */\n.tag--warning {\n  background: var(--Yellow-500);\n  color: var(--Text-Blue-text-Main-text);\n}\n\n.tag--warning:hover,\n.tag--warning.tag--hover {\n  background: var(--color-yellow-600);\n}\n\n.tag--warning .tag__remove svg {\n  color: var(--Text-Blue-text-Main-text);\n}\n\n/* Neutral scheme */\n.tag--neutral {\n  background: var(--sds-color-background-neutral-tertiary);\n  color: var(--Text-Blue-text-Main-text);\n}\n\n.tag--neutral:hover,\n.tag--neutral.tag--hover {\n  background: var(--sds-color-background-neutral-secondary);\n}\n\n.tag--neutral .tag__remove svg {\n  color: var(--Text-Blue-text-Main-text);\n}\n"],["STYLE",{},"/* MultiSelect component styles matching Figma design */\n.multiselect {\n  position: relative;\n  width: 100%;\n  min-width: 240px;\n  background: var(--Inputs-Input-Background);\n  border-radius: var(--sds-size-radius-200);\n  font-family: var(--font-family-macan);\n}\n\n.multiselect--disabled {\n  opacity: 0.6;\n  cursor: not-allowed;\n}\n\n.multiselect__field-body {\n  display: flex;\n  flex-wrap: wrap;\n  align-items: center;\n  align-content: center;\n  gap: var(--sds-size-space-200);\n  padding: var(--sds-size-space-200) var(--sds-size-space-300);\n  min-height: 40px;\n  background: var(--Inputs-Input-Background);\n}\n\n.multiselect__input-container {\n  display: flex;\n  align-items: center;\n  gap: var(--sds-size-space-200);\n  padding: var(--sds-size-space-300) var(--sds-size-space-400) var(--sds-size-space-300) var(--sds-size-space-400);\n  background: var(--Inputs-Input-Background);\n}\n\n.multiselect--has-tags .multiselect__input-container {\n  border-top: 1px solid rgba(0, 0, 0, 0.1);\n}\n\n.multiselect__input {\n  flex: 1;\n  border: none;\n  background: transparent;\n  font-family: var(--font-family-macan);\n  font-size: 16px;\n  font-weight: 450;\n  line-height: 120%;\n  letter-spacing: -0.32px;\n  color: var(--Text-Blue-text-Main-text);\n  outline: none;\n}\n\n.multiselect__input::-moz-placeholder {\n  color: var(--Inputs-Placeholder-text);\n}\n\n.multiselect__input::placeholder {\n  color: var(--Inputs-Placeholder-text);\n}\n\n.multiselect__input:disabled {\n  cursor: not-allowed;\n}\n\n.multiselect__controls {\n  display: flex;\n  align-items: center;\n  gap: var(--sds-size-space-100);\n  flex-shrink: 0;\n}\n\n.multiselect__count {\n  color: var(--Text-Blue-text-Main-text);\n  font-family: var(--font-family-macan);\n  font-size: 16px;\n  font-weight: 450;\n  line-height: 120%;\n  letter-spacing: -0.32px;\n  text-align: right;\n}\n\n.multiselect__toggle {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 20px;\n  height: 20px;\n  padding: 0;\n  border: none;\n  background: none;\n  cursor: pointer;\n  color: var(--Inputs-Placeholder-text);\n  transition: transform 0.2s ease;\n}\n\n.multiselect__toggle:hover {\n  color: var(--Text-Blue-text-Main-text);\n}\n\n.multiselect__toggle:disabled {\n  cursor: not-allowed;\n  opacity: 0.5;\n}\n\n.multiselect__toggle-icon--up {\n  transform: rotate(180deg);\n}\n\n.multiselect__toggle-icon--down {\n  transform: rotate(0deg);\n}\n\n.multiselect__dropdown {\n  position: relative;\n  z-index: 1;\n  background: var(--surface-card);\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--sds-size-radius-200);\n  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);\n  overflow-y: auto;\n  margin-top: 2px;\n}\n\n.multiselect__options {\n  list-style: none;\n  margin: 0;\n  padding: var(--sds-size-space-100) 0;\n}\n\n.multiselect__option {\n  padding: var(--sds-size-space-200) var(--sds-size-space-400);\n  cursor: pointer;\n  font-family: var(--font-family-macan);\n  font-size: 16px;\n  font-weight: 450;\n  line-height: 120%;\n  letter-spacing: -0.32px;\n  color: var(--Text-Blue-text-Main-text);\n  transition: background-color 0.2s ease;\n}\n\n.multiselect__option:hover,\n.multiselect__option--active {\n  background: var(--sds-color-background-neutral-tertiary);\n}\n\n.multiselect__option--create {\n  font-style: italic;\n  color: var(--text-blue-secondary);\n  border-top: 1px solid var(--border-subtle);\n  margin-top: var(--sds-size-space-100);\n}\n\n.multiselect__option--create:hover,\n.multiselect__option--create.multiselect__option--active {\n  background: var(--sds-color-background-brand-tertiary);\n  color: var(--Text-Blue-text-Main-text);\n}\n\n.multiselect__empty {\n  padding: var(--sds-size-space-200) var(--sds-size-space-400);\n  font-family: var(--font-family-macan);\n  font-size: 14px;\n  font-weight: 450;\n  line-height: 120%;\n  color: var(--Inputs-Placeholder-text);\n}\n\n/* Focus styles for accessibility */\n.multiselect__input:focus-visible {\n  outline: 2px solid var(--color-blue-700);\n  outline-offset: 1px;\n}\n\n.multiselect__toggle:focus-visible {\n  outline: 2px solid var(--color-blue-700);\n  outline-offset: 1px;\n  border-radius: 2px;\n}\n\n/* Responsive adjustments */\n@media (max-width: 768px) {\n  .multiselect {\n    width: 100%;\n    min-width: auto;\n  }\n}\n\n/* Dark mode support */\n@media (prefers-color-scheme: dark) {\n  .multiselect__dropdown {\n    border-color: var(--divider-dark);\n  }\n  \n  .multiselect__option--create {\n    border-top-color: var(--divider-dark);\n  }\n}\n\n[data-theme=\"dark\"] .multiselect__dropdown {\n  border-color: var(--divider-dark);\n}\n\n[data-theme=\"dark\"] .multiselect__option--create {\n  border-top-color: var(--divider-dark);\n}\n"],["STYLE",{},"/*! tailwindcss v4.1.18 | MIT License | https://tailwindcss.com */\n@layer properties;\n@layer theme, base, components, utilities;\n@layer theme {\n  :root, :host {\n 