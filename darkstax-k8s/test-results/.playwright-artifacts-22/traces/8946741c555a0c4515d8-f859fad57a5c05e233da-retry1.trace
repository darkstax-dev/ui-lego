s: false;\n  initial-value: 0px;\n}\n@property --tw-ring-offset-color {\n  syntax: \"*\";\n  inherits: false;\n  initial-value: #fff;\n}\n@property --tw-ring-offset-shadow {\n  syntax: \"*\";\n  inherits: false;\n  initial-value: 0 0 #0000;\n}\n@property --tw-outline-style {\n  syntax: \"*\";\n  inherits: false;\n  initial-value: solid;\n}\n@property --tw-blur {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-brightness {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-contrast {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-grayscale {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-hue-rotate {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-invert {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-opacity {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-saturate {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-sepia {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-drop-shadow {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-drop-shadow-color {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-drop-shadow-alpha {\n  syntax: \"<percentage>\";\n  inherits: false;\n  initial-value: 100%;\n}\n@property --tw-drop-shadow-size {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-backdrop-blur {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-backdrop-brightness {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-backdrop-contrast {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-backdrop-grayscale {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-backdrop-hue-rotate {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-backdrop-invert {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-backdrop-opacity {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-backdrop-saturate {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-backdrop-sepia {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-ease {\n  syntax: \"*\";\n  inherits: false;\n}\n@property --tw-scale-x {\n  syntax: \"*\";\n  inherits: false;\n  initial-value: 1;\n}\n@property --tw-scale-y {\n  syntax: \"*\";\n  inherits: false;\n  initial-value: 1;\n}\n@property --tw-scale-z {\n  syntax: \"*\";\n  inherits: false;\n  initial-value: 1;\n}\n@layer properties {\n  @supports ((-webkit-hyphens: none) and (not (margin-trim: inline))) or ((-moz-orient: inline) and (not (color:rgb(from red r g b)))) {\n    *, ::before, ::after, ::backdrop {\n      --tw-translate-x: 0;\n      --tw-translate-y: 0;\n      --tw-translate-z: 0;\n      --tw-rotate-x: initial;\n      --tw-rotate-y: initial;\n      --tw-rotate-z: initial;\n      --tw-skew-x: initial;\n      --tw-skew-y: initial;\n      --tw-space-y-reverse: 0;\n      --tw-border-style: solid;\n      --tw-leading: initial;\n      --tw-font-weight: initial;\n      --tw-tracking: initial;\n      --tw-shadow: 0 0 #0000;\n      --tw-shadow-color: initial;\n      --tw-shadow-alpha: 100%;\n      --tw-inset-shadow: 0 0 #0000;\n      --tw-inset-shadow-color: initial;\n      --tw-inset-shadow-alpha: 100%;\n      --tw-ring-color: initial;\n      --tw-ring-shadow: 0 0 #0000;\n      --tw-inset-ring-color: initial;\n      --tw-inset-ring-shadow: 0 0 #0000;\n      --tw-ring-inset: initial;\n      --tw-ring-offset-width: 0px;\n      --tw-ring-offset-color: #fff;\n      --tw-ring-offset-shadow: 0 0 #0000;\n      --tw-outline-style: solid;\n      --tw-blur: initial;\n      --tw-brightness: initial;\n      --tw-contrast: initial;\n      --tw-grayscale: initial;\n      --tw-hue-rotate: initial;\n      --tw-invert: initial;\n      --tw-opacity: initial;\n      --tw-saturate: initial;\n      --tw-sepia: initial;\n      --tw-drop-shadow: initial;\n      --tw-drop-shadow-color: initial;\n      --tw-drop-shadow-alpha: 100%;\n      --tw-drop-shadow-size: initial;\n      --tw-backdrop-blur: initial;\n      --tw-backdrop-brightness: initial;\n      --tw-backdrop-contrast: initial;\n      --tw-backdrop-grayscale: initial;\n      --tw-backdrop-hue-rotate: initial;\n      --tw-backdrop-invert: initial;\n      --tw-backdrop-opacity: initial;\n      --tw-backdrop-saturate: initial;\n      --tw-backdrop-sepia: initial;\n      --tw-ease: initial;\n      --tw-scale-x: 1;\n      --tw-scale-y: 1;\n      --tw-scale-z: 1;\n    }\n  }\n}\n"],["STYLE",{},"/* Design Tokens - Variable Collection */\n/* Generated from Figma design system documentation */\n\n:root {\n  /* ===== SIMPLE DESIGN SYSTEM (SDS) TOKENS ===== */\n\n  /* Spacing Scale */\n  --sds-size-space-100: 4px;\n  --sds-size-space-200: 8px;\n  --sds-size-space-300: 12px;\n  --sds-size-space-400: 16px;\n  --sds-size-space-600: 24px;\n  --sds-size-space-800: 32px;\n  --sds-size-space-1600: 64px;\n  --sds-size-space-2400: 96px;\n  --sds-size-space-4000: 160px;\n\n  /* SDS Padding Scale */\n  --sds-size-padding-xs: 4px;\n  --sds-size-padding-sm: 8px;\n  --sds-size-padding-lg: 16px;\n\n  /* SDS Size Scale for Radius */\n  --sds-radius-md: 0px;\n  --sds-size-radius-400: 0px;\n  --sds-size-radius-200: 0px;\n\n  /* Negative Spacing */\n  --sds-size-space-negative-100: -4px;\n  --sds-size-space-negative-200: -8px;\n  --sds-size-space-negative-300: -12px;\n  --sds-size-space-negative-400: -16px;\n  --sds-size-space-negative-600: -24px;\n\n  /* Border Radius - All set to 0 (none) */\n  --sds-size-radius-100: 0px;\n  --sds-size-radius-200: 0px;\n  --sds-size-radius-400: 0px;\n  --sds-size-radius-full: 0px;\n\n  /* Depth/Shadows */\n  --sds-size-depth-0: 0px;\n  --sds-size-depth-025: 1px;\n  --sds-size-depth-100: 4px;\n  --sds-size-depth-400: 16px;\n  --sds-size-depth-800: 32px;\n  --sds-size-depth-negative-025: -1px;\n  --sds-size-depth-negative-100: -4px;\n  --sds-size-depth-negative-200: -8px;\n\n  /* Stroke/Border Sizes */\n  --sds-size-stroke-border: 1px;\n\n  /* SDS Color System - Neutrals */\n  --sds-color-border-neutral-tertiary: #b2b2b2;\n  --sds-color-background-neutral-secondary: #cdcdcd;\n  --sds-color-background-neutral-tertiary: #e3e3e3;\n  --sds-color-text-neutral-on-neutral-secondary: #303030;\n  --sds-color-text-neutral-on-neutral-tertiary: #434343;\n  --sds-color-background-default-default: #cecece;\n\n  /* SDS Color System - Text */\n  --sds-color-text-default-default: #1e1e1e;\n  --sds-color-text-default-secondary: #757575;\n  --sds-color-text-brand-on-brand: #f5f5f5;\n  --sds-color-text-brand-tertiary: #757575;\n  --sds-color-text-danger-on-danger: #fee9e7;\n  --sds-color-text-positive-on-positive: #ebffee;\n  --sds-color-text-disabled-default: #b3b3b3;\n\n  /* SDS Color System - Borders */\n  --sds-color-border-default-default: #d9d9d9;\n\n  /* Background Colors from Figma */\n  --Background-Card: #DFDFDF;\n\n  /* SDS Color System - Utilities */\n  --sds-color-background-utilities-measurement: #fae1fa;\n  --sds-color-border-utilities-swatch: rgba(0, 0, 0, 0.24);\n\n  /* SDS Color System - Warning States */\n  --sds-color-border-warning-default: #522504;\n  --sds-color-background-warning-secondary: #fff1c2;\n  --sds-color-text-warning-on-warning-secondary: #682d03;\n\n  /* SDS Color System - Black/Transparency */\n  --sds-color-black-100: rgba(12, 12, 13, 0.05);\n  --sds-color-black-200: rgba(12, 12, 13, 0.1);\n  --sds-color-black-400: rgba(12, 12, 13, 0.4);\n\n  /* SDS Blur and Effect Utilities */\n  --sds-size-blur-100: 4px;\n  --sds-color-background-utilities-overlay: rgba(0, 0, 0, 0.5);\n  --sds-color-background-utilities-blanket: rgba(0, 0, 0, 0.7);\n  --sds-color-background-utilities-scrim: rgba(255, 255, 255, 0.8);\n\n  /* SDS Padding */\n  --sds-size-padding-xl: 24px;\n\n  /* SDS Brand Colors */\n  --sds-color-background-brand-default: #2c2c2c;\n  --sds-color-background-brand-tertiary: #f5f5f5;\n  --Gray-50: #FFF;\n  --Brown-Main-900: #403B39;\n  --Black: #0E0E0E;\n  --Yellow-500: #ED8B30;\n\n  /* ===== TYPOGRAPHY TOKENS ===== */\n\n  /* Font Families */\n  --font-family-macan: 'Macan', -apple-system, Roboto, Helvetica, sans-serif;\n  --font-family-macan-mono: 'Macan Mono Trial', -apple-system, Roboto, Helvetica, sans-serif;\n  --font-family-macan-mono-stencil: 'Macan Mono Stencil Trial', -apple-system, Roboto, Helvetica, sans-serif;\n  --font-family-inter: 'Inter', -apple-system, Roboto, Helvetica, sans-serif;\n\n  /* SDS Typography System */\n  --sds-typography-body-font-family: 'Inter', -apple-system, Roboto, Helvetica, sans-serif;\n  --sds-typography-body-size-small: 14px;\n  --sds-typography-body-size-medium: 16px;\n  --sds-typography-body-font-weight-regular: 400;\n  --sds-typography-body-font-weight-strong: 700;\n  --sds-typography-family-mono: 'Roboto Mono', -apple-system, Roboto, Helvetica, sans-serif;\n  --sds-typography-scale-03: 16px;\n  --sds-typography-weight-regular: 400;\n\n  /* Font Weights */\n  --font-weight-book: 450;\n  --font-weight-medium: 500;\n  --font-weight-semibold: 600;\n  --font-weight-bold: 700;\n\n  /* Font Sizes */\n  --font-size-xs: 12px;\n  --font-size-sm: 14px;\n  --font-size-base: 15px;\n  --font-size-md: 16px;\n  --font-size-lg: 18px;\n  --font-size-xl: 24px;\n  --font-size-2xl: 32px;\n  --font-size-3xl: 40px;\n\n  /* Line Heights */\n  --line-height-tight: 110%;\n  --line-height-normal: 120%;\n\n  /* Letter Spacing */\n  --letter-spacing-tight: -0.02em; /* -2% */\n  --letter-spacing-normal: 0;\n  --letter-spacing-wide: 0.05em; /* 5% */\n  --letter-spacing-wider: 0.1em; /* 10% */\n\n  /* ===== BASE COLOR PALETTE ===== */\n  \n  /* Blue Scale */\n  --color-blue-dark-950: #00112b;\n  --color-blue-medium-950: #071f42;\n  --color-blue-950: #072b56;\n  --color-blue-800: #0451a4;\n  --color-blue-700: #0072ff;\n  --color-blue-gray-600: #868d97;\n  --color-blue-gray-500: #a3aab1;\n  --color-blue-gray-400: #b9b9b9;\n  --color-blue-60: #071f42;\n\n  /* Gray Scale */\n  --color-gray-500: #78797a;\n  --color-gray-400: #adadad;\n  --color-gray-300: #cecece;\n  --color-gray-200: #dfdfdf;\n  --color-gray-100: #ececec;\n\n  /* Red Scale */\n  --color-red-700: #b6261f;\n  --color-red-600: #d9322a;\n  --color-red-500: #ff3b31;\n  --color-red-400: #ff6c64;\n  --color-red-300: #ffa29d;\n  --color-red-200: #ffcbc8;\n  --color-red-100: #ffe3e1;\n  --color-red-50: #fef3f2;\n\n  /* Green Scale */\n  --color-green-800: #108541;\n  --color-green-600: #23a45a;\n  --color-green-500: #2eb969;\n  --color-green-400: #55d38a;\n  --color-green-300: #8ee7b3;\n  --color-green-200: #bff3d5;\n  --color-green-100: #defaea;\n\n  /* Yellow/Orange Scale */\n  --color-yellow-600: #dd6a19;\n  --color-yellow-500: #ed8b30;\n  --color-yellow-400: #f09f47;\n  --color-yellow-300: #f5c37c;\n  --color-yellow-200: #f9ddaf;\n  --color-yellow-100: #fdf0d7;\n\n  /* Neutral Colors */\n  --color-white: #ffffff;\n  --color-black: #0e0e0e;\n\n  /* ===== FIGMA DESIGN TOKEN ALIASES ===== */\n\n  /* Figma-specific token names for SecondaryNavigation */\n  --Text-Blue-text-Main-text: var(--text-blue-main, var(--color-blue-dark-950));\n  --red-600-cta: var(--color-red-600);\n  --Inputs-Input-Background: var(--color-gray-200);\n  --Inputs-Placeholder-text: var(--color-gray-500);\n  --Gray-200: var(--color-gray-200);\n  --Gray-500: var(--color-gray-500);\n  --Icon-Button-Gray-btn-Fill: var(--color-gray-200);\n  --Primary-button-red-Icon-default: var(--color-white);\n  --Primary-button-red-Fill: var(--color-red-600);\n  --Text-White-text-Main-text: var(--color-white);\n\n  /* Figma modeling component tokens */\n  --Text-Blue-text-Tetriary-text: var(--color-blue-950);\n  --Modeling-Items-Modeling-item-hover: rgba(255, 255, 255, 0.60);\n  --Modeling-Items-Modeling-item: rgba(255, 255, 255, 0.40);\n  --white-white-100: var(--color-white);\n  --Green-Green-800: var(--color-green-800);\n  --White: var(--color-white);\n  --white-white-40: rgba(255, 255, 255, 0.40);\n  --Dark-blue: var(--color-blue-dark-950);\n  --color-gray-50: #F8F8F8;\n  --Gray-50: var(--color-gray-50);\n  --white-white-20: rgba(255, 255, 255, 0.20);\n  --Gray-100: var(--color-gray-100);\n\n  /* Additional Figma design tokens for buttons */\n  --Primary-button-red-Disabled: #ADADAD;\n  --Text-White-text-Secondary-text: #DFDFDF;\n  --Blue-Dark-blue-950: #00112B;\n  --white-white-100: #FFF;\n  --Text-Gray-text-Disabled-text: #CECECE;\n  --Red-500: #FF3B31;\n  --Icon-Button-Disabled: #CECECE;\n  --Divider-Light: #C8C8C8;\n  --Divider-dark: #072B56;\n\n  /* Figma dropdown design tokens */\n  --Text-Blue-text-Main-text: var(--text-blue-main, #00112B);\n  --Blue-Dark-blue-950: #00112B;\n  --Drop-down-light-Background-default: #ECECEC;\n  --Gray-300: #CECECE;\n\n  /* ===== SEMANTIC TOKENS - LIGHT MODE ===== */\n\n  /* Navigation */\n  --nav-main-bg: var(--color-blue-dark-950);\n  --nav-secondary-bg: var(--color-gray-300);\n\n  /* Surfaces */\n  --surface-default: var(--bg-default, var(--color-gray-300));\n  --surface-card: var(--bg-card, var(--color-gray-200));\n  --surface-subtle: #f8f9fa;\n  --border-subtle: #e9ecef;\n\n  /* Text Colors */\n  --text-blue-main: var(--color-blue-dark-950);\n  --text-blue-secondary: var(--color-blue-medium-950);\n  --text-blue-tertiary: var(--color-blue-950);\n\n  --text-gray-main: var(--color-gray-500);\n  --text-gray-secondary: var(--color-gray-400);\n  --text-gray-disabled: var(--color-gray-300);\n\n  /* Body text tokens for docs/demo surfaces */\n  --text-body-strong: #333333;\n  --text-body-muted: #666666;\n\n  --text-white-main: var(--color-white);\n  --text-white-secondary: var(--color-gray-200);\n  --text-white-tertiary: var(--color-gray-500);\n\n  /* Input Labels */\n  --input-label-text: var(--text-blue-main);\n\n  /* Button Colors */\n  --btn-primary-red-fill: var(--color-red-600);\n  --btn-primary-red-hover: var(--color-red-400);\n  --btn-primary-red-danger: var(--color-red-50);\n\n  --btn-icon-gray-fill: var(--color-gray-200);\n  --btn-icon-white-fill: var(--color-gray-100);\n  --btn-icon-hover: var(--color-blue-dark-950);\n  --btn-icon-danger: var(--color-red-500);\n  --btn-icon-disabled: var(--color-gray-300);\n  --btn-icon-default: var(--color-gray-500);\n\n  /* Dividers */\n  --divider-light: #c8c8c8;\n  --divider-dark: var(--color-blue-950);\n}\n\n/* ===== DARK MODE OVERRIDES ===== */\n@media (prefers-color-scheme: dark) {\n  :root {\n    /* Figma token aliases - dark mode */\n    --Text-Blue-text-Main-text: var(--color-gray-200);\n    --Inputs-Input-Background: var(--color-blue-dark-950);\n    --Inputs-Placeholder-text: var(--color-gray-400);\n    --Gray-200: var(--color-blue-dark-950);\n    --Gray-500: var(--color-gray-400);\n    --Icon-Button-Gray-btn-Fill: var(--color-blue-950);\n\n    /* Navigation */\n    --nav-main-bg: var(--color-blue-medium-950);\n    --nav-secondary-bg: var(--color-blue-dark-950);\n\n    /* Backgrounds */\n    --bg-default: var(--color-blue-medium-950);\n    --bg-card: var(--color-blue-dark-950);\n\n    /* Surfaces */\n    --surface-default: var(--bg-default);\n    --surface-card: var(--bg-card);\n    --surface-subtle: var(--color-blue-60);\n    --border-subtle: var(--divider-light);\n\n    /* Text Colors */\n    --text-blue-main: var(--color-gray-200);\n    --text-blue-secondary: var(--color-gray-300);\n    --text-blue-tertiary: var(--color-gray-400);\n\n    --text-gray-main: var(--color-gray-200);\n    --text-gray-secondary: var(--color-gray-400);\n    --text-gray-disabled: var(--color-gray-500);\n\n    /* Body text tokens for docs/demo surfaces */\n    --text-body-strong: var(--text-white-main);\n    --text-body-muted: var(--text-white-secondary);\n\n    --text-white-main: var(--color-gray-200);\n    --text-white-secondary: var(--color-gray-300);\n    --text-white-tertiary: var(--color-gray-400);\n\n    /* Input Labels */\n    --input-label-text: var(--text-white-main);\n\n    /* Button Colors */\n    --btn-primary-red-fill: var(--color-red-600);\n    --btn-primary-red-hover: var(--color-red-400);\n    --btn-primary-red-danger: var(--color-red-50);\n\n    --btn-icon-gray-fill: var(--color-blue-950);\n    --btn-icon-white-fill: var(--color-gray-200);\n    --btn-icon-hover: var(--color-blue-dark-950);\n    --btn-icon-danger: var(--color-red-500);\n    --btn-icon-disabled: var(--color-blue-60);\n    --btn-icon-default: var(--text-white-main);\n\n    /* Dividers */\n    --divider-light: var(--color-blue-950);\n    --divider-dark: #c8c8c8;\n  }\n}\n\n/* ===== MANUAL DARK MODE CLASS ===== */\n[data-theme=\"dark\"] {\n  /* Figma token aliases - manual dark mode */\n  --Text-Blue-text-Main-text: var(--color-gray-200);\n  --Inputs-Input-Background: var(--color-blue-dark-950);\n  --Inputs-Placeholder-text: var(--color-gray-400);\n  --Gray-200: var(--color-blue-dark-950);\n  --Gray-500: var(--color-gray-400);\n  --Icon-Button-Gray-btn-Fill: var(--color-blue-950);\n\n  /* Navigation */\n  --nav-main-bg: var(--color-blue-medium-950);\n  --nav-secondary-bg: var(--color-blue-dark-950);\n\n  /* Backgrounds */\n  --bg-default: var(--color-blue-medium-950);\n  --bg-card: var(--color-blue-dark-950);\n\n  /* Surfaces */\n  --surface-default: var(--bg-default);\n  --surface-card: var(--bg-card);\n  --surface-subtle: var(--color-blue-60);\n  --border-subtle: var(--divider-light);\n\n  /* Text Colors */\n  --text-blue-main: var(--color-gray-200);\n  --text-blue-secondary: var(--color-gray-300);\n  --text-blue-tertiary: var(--color-gray-400);\n\n  --text-gray-main: var(--color-gray-200);\n  --text-gray-secondary: var(--color-gray-400);\n  --text-gray-disabled: var(--color-gray-500);\n\n  /* Body text tokens for docs/demo surfaces */\n  --text-body-strong: var(--text-white-main);\n  --text-body-muted: var(--text-white-secondary);\n\n  --text-white-main: var(--color-gray-200);\n  --text-white-secondary: var(--color-gray-300);\n  --text-white-tertiary: var(--color-gray-400);\n\n  /* Input Labels */\n  --input-label-text: var(--text-white-main);\n\n  /* Button Colors */\n  --btn-primary-red-fill: var(--color-red-600);\n  --btn-primary-red-hover: var(--color-red-400);\n  --btn-primary-red-danger: var(--color-red-50);\n\n  --btn-icon-gray-fill: var(--color-blue-950);\n  --btn-icon-white-fill: var(--color-gray-200);\n  --btn-icon-hover: var(--color-blue-dark-950);\n  --btn-icon-danger: var(--color-red-500);\n  --btn-icon-disabled: var(--color-blue-60);\n  --btn-icon-default: var(--text-white-main);\n\n  /* Dividers */\n  --divider-light: var(--color-blue-950);\n  --divider-dark: #c8c8c8;\n}\n\n/* ===== UTILITY CLASSES ===== */\n\n/* Status Colors */\n.status-success { color: var(--color-green-600); }\n.status-warning { color: var(--color-yellow-500); }\n.status-error { color: var(--color-red-500); }\n.status-info { color: var(--color-blue-700); }\n\n/* Background Status Colors */\n.bg-success { background-color: var(--color-green-100); }\n.bg-warning { background-color: var(--color-yellow-100); }\n.bg-error { background-color: var(--color-red-100); }\n.bg-info { background-color: #0072ff1a; }\n\n/* Text Variants */\n.text-primary { color: var(--text-blue-main); }\n.text-secondary { color: var(--text-blue-secondary); }\n.text-tertiary { color: var(--text-blue-tertiary); }\n.text-disabled { color: var(--text-gray-disabled); }\n.text-on-dark { color: var(--text-white-main); }\n.text-on-light { color: var(--text-blue-main); }\n\n/* Interactive States */\n.interactive:hover { opacity: 0.8; }\n.interactive:active { opacity: 0.6; }\n.interactive:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n/* ===== TYPOGRAPHY UTILITY CLASSES ===== */\n\n/* Font Face Declarations */\n@font-face {\n  font-family: 'Macan';\n  src: url('/fonts/Macan-Bold.woff2') format('woff2'),\n       url('/fonts/Macan-Bold.woff') format('woff');\n  font-weight: var(--font-weight-bold);\n  font-style: normal;\n  font-display: swap;\n}\n\n@font-face {\n  font-family: 'Macan Mono Trial';\n  src: url('/fonts/Macan-Mono-Bold.woff2') format('woff2'),\n       url('/fonts/Macan-Mono-Bold.woff') format('woff');\n  font-weight: var(--font-weight-bold);\n  font-style: normal;\n  font-display: swap;\n}\n\n@font-face {\n  font-family: 'Macan Mono Stencil Trial';\n  src: url('/fonts/Macan-Mono-Stencil-Bold.woff2') format('woff2'),\n       url('/fonts/Macan-Mono-Stencil-Bold.woff') format('woff');\n  font-weight: var(--font-weight-bold);\n  font-style: normal;\n  font-display: swap;\n}\n\n@font-face {\n  font-family: 'Macan Mono Stencil Trial';\n  src: url('/fonts/Macan-Mono-Stencil-Regular.woff2') format('woff2'),\n       url('/fonts/Macan-Mono-Stencil-Regular.woff') format('woff');\n  font-weight: var(--font-weight-medium);\n  font-style: normal;\n  font-display: swap;\n}\n\n/* Heading Styles */\n.heading-page {\n  font-family: var(--font-family-macan-mono-stencil);\n  font-size: var(--font-size-3xl);\n  font-weight: var(--font-weight-medium);\n  line-height: var(--line-height-normal);\n  letter-spacing: var(--letter-spacing-wide);\n  text-transform: uppercase;\n}\n\n.heading-page-2 {\n  font-family: var(--font-family-macan-mono-stencil);\n  font-size: var(--font-size-2xl);\n  font-weight: var(--font-weight-medium);\n  line-height: var(--line-height-normal);\n  letter-spacing: var(--letter-spacing-wide);\n  text-transform: uppercase;\n}\n\n.heading-subheading-macan {\n  font-family: var(--font-family-macan);\n  font-size: var(--font-size-xl);\n  font-weight: var(--font-weight-medium);\n  line-height: var(--line-height-normal);\n  letter-spacing: var(--letter-spacing-tight);\n}\n\n.heading-subheading-stencil {\n  font-family: var(--font-family-macan-mono-stencil);\n  font-size: var(--font-size-xl);\n  font-weight: var(--font-weight-medium);\n  line-height: var(--line-height-tight);\n  letter-spacing: var(--letter-spacing-wide);\n  text-transform: uppercase;\n}\n\n/* Emphasis Styles */\n.emphasis-body-mono-lg {\n  font-family: var(--font-family-macan-mono);\n  font-size: var(--font-size-md);\n  font-weight: var(--font-weight-semibold);\n  line-height: var(--line-height-tight);\n  letter-spacing: var(--letter-spacing-wider);\n  text-transform: uppercase;\n}\n\n.emphasis-body-mono-sm {\n  font-family: var(--font-family-macan-mono);\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-semibold);\n  line-height: var(--line-height-tight);\n  letter-spacing: var(--letter-spacing-wider);\n  text-transform: uppercase;\n}\n\n/* Body Base Styles */\n.body-base-macan-semibold-lg {\n  font-family: var(--font-family-macan);\n  font-size: var(--font-size-lg);\n  font-weight: var(--font-weight-semibold);\n  line-height: var(--line-height-normal);\n  letter-spacing: var(--letter-spacing-tight);\n}\n\n.body-base-macan-semibold {\n  font-family: var(--font-family-macan);\n  font-size: var(--font-size-md);\n  font-weight: var(--font-weight-semibold);\n  line-height: var(--line-height-normal);\n  letter-spacing: var(--letter-spacing-tight);\n}\n\n.body-base-macan-book {\n  font-family: var(--font-family-macan);\n  font-size: var(--font-size-md);\n  font-weight: var(--font-weight-book);\n  line-height: var(--line-height-normal);\n  letter-spacing: var(--letter-spacing-tight);\n}\n\n.body-base-mono-medium {\n  font-family: var(--font-family-macan-mono);\n  font-size: var(--font-size-md);\n  font-weight: var(--font-weight-medium);\n  line-height: var(--line-height-tight);\n  letter-spacing: var(--letter-spacing-normal);\n}\n\n.body-base-mono-book-lg {\n  font-family: var(--font-family-macan-mono);\n  font-size: var(--font-size-base);\n  font-weight: var(--font-weight-book);\n  line-height: var(--line-height-normal);\n  letter-spacing: var(--letter-spacing-normal);\n}\n\n.body-base-mono-book {\n  font-family: var(--font-family-macan-mono);\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-book);\n  line-height: var(--line-height-normal);\n  letter-spacing: var(--letter-spacing-normal);\n}\n\n/* Body Small Styles */\n.body-small-mono-book {\n  font-family: var(--font-family-macan-mono);\n  font-size: var(--font-size-xs);\n  font-weight: var(--font-weight-book);\n  line-height: var(--line-height-normal);\n  letter-spacing: var(--letter-spacing-wider);\n}\n\n.body-small-macan-book {\n  font-family: var(--font-family-macan);\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-book);\n  line-height: var(--line-height-normal);\n  letter-spacing: var(--letter-spacing-normal);\n}\n\n/* Font Family Utilities */\n.font-macan { font-family: var(--font-family-macan); }\n.font-macan-mono { font-family: var(--font-family-macan-mono); }\n.font-macan-mono-stencil { font-family: var(--font-family-macan-mono-stencil); }\n.font-inter { font-family: var(--font-family-inter); }\n\n/* Font Weight Utilities */\n.font-book { font-weight: var(--font-weight-book); }\n.font-medium { font-weight: var(--font-weight-medium); }\n.font-semibold { font-weight: var(--font-weight-semibold); }\n.font-bold { font-weight: var(--font-weight-bold); }\n\n/* Font Size Utilities */\n.text-xs { font-size: var(--font-size-xs); }\n.text-sm { font-size: var(--font-size-sm); }\n.text-base { font-size: var(--font-size-base); }\n.text-md { font-size: var(--font-size-md); }\n.text-lg { font-size: var(--font-size-lg); }\n.text-xl { font-size: var(--font-size-xl); }\n.text-2xl { font-size: var(--font-size-2xl); }\n.text-3xl { font-size: var(--font-size-3xl); }\n\n/* Line Height Utilities */\n.leading-tight { line-height: var(--line-height-tight); }\n.leading-normal { line-height: var(--line-height-normal); }\n\n/* Letter Spacing Utilities */\n.tracking-tight { letter-spacing: var(--letter-spacing-tight); }\n.tracking-normal { letter-spacing: var(--letter-spacing-normal); }\n.tracking-wide { letter-spacing: var(--letter-spacing-wide); }\n.tracking-wider { letter-spacing: var(--letter-spacing-wider); }\n\n/* Text Transform Utilities */\n.uppercase { text-transform: uppercase; }\n.lowercase { text-transform: lowercase; }\n.capitalize { text-transform: capitalize; }\n.normal-case { text-transform: none; }\n"]],"\n  ",["BODY",{},"\n    ",["DIV",{"id":"root"},["DIV",{"class":"h-screen w-screen flex flex-col bg-gray-100 overflow-hidden"},["DIV",{"class":"flex-1 flex overflow-hidden"},["DIV",{"class":"f